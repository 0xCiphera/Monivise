<div class="mv-bucket-row" @onclick="HandleClick">
    <div class="mv-bucket-row__icon" style="background:@BgTint(Bucket.Type); color:@TextTint(Bucket.Type);">
        <Icon Name="@IconFor(Bucket.Type)" Size="18" />
    </div>
    <div class="mv-bucket-row__body">
        <p class="mv-bucket-row__name">@Bucket.Name</p>
        <p class="mv-bucket-row__meta">@Subtitle(Bucket)</p>
        @if (Bucket.Type != "Fixed")
        {
            <div class="mv-bucket-row__track">
                <div class="mv-bucket-row__fill" style="width:@(UsedPercent(Bucket))%; background:@TextTint(Bucket.Type);"></div>
            </div>
        }
    </div>
    <p class="mv-bucket-row__amount">@CurrencyFormatter.Format(Bucket.Balance)</p>
</div>

<style>
    .mv-bucket-row {
        display: flex;
        align-items: center;
        gap: 10px;
        border: 1px solid var(--mv-border);
        border-radius: var(--mv-radius-md);
        padding: 10px 12px;
        cursor: pointer;
    }

        .mv-bucket-row:active {
            background: var(--mv-surface-sunken);
        }

    .mv-bucket-row__icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .mv-bucket-row__body {
        flex: 1;
        min-width: 0;
    }

    .mv-bucket-row__name {
        font-size: var(--mv-fs-md);
        margin: 0;
    }

    .mv-bucket-row__meta {
        font-size: var(--mv-fs-xs);
        color: var(--mv-text-tertiary);
        margin: 2px 0 0;
    }

    .mv-bucket-row__track {
        height: 4px;
        border-radius: 2px;
        background: var(--mv-border);
        margin-top: 6px;
        overflow: hidden;
    }

    .mv-bucket-row__fill {
        height: 100%;
        border-radius: 2px;
        transition: width 0.3s ease;
    }

    .mv-bucket-row__amount {
        font-size: var(--mv-fs-md);
        font-weight: 600;
        margin: 0;
    }
</style>

@code {
    [Parameter] public BucketDto Bucket { get; set; } = default!;
    [Parameter] public EventCallback<BucketDto> OnSelect { get; set; }

    private Task HandleClick() => OnSelect.HasDelegate ? OnSelect.InvokeAsync(Bucket) : Task.CompletedTask;

    private static decimal UsedPercent(BucketDto b) =>
        b.Allocated > 0 ? Math.Min(100, Math.Max(0, b.Spent / b.Allocated * 100)) : 0;

    // Fixed Obligations' real subtitle ("3 of 5 paid this month") needs the
    // paid/unpaid checklist data — that lives behind FixedObligationApiClient,
    // not on BucketDto itself. Fetching it here would mean an extra API call
    // per dashboard load just for this one line of text; deferring the real
    // version to the Fixed Obligations page phase rather than faking it or
    // adding that round-trip now.
    private static string Subtitle(BucketDto b) => b.Type switch
    {
        "Fixed" => b.Allocated > 0 ? $"{CurrencyFormatter.Format(b.Allocated)} reserved this month" : "Nothing reserved yet",
        "Flexible" => b.Allocated > 0
            ? $"{CurrencyFormatter.Format(b.Balance)} left of {CurrencyFormatter.Format(b.Allocated)}"
            : "No allocation yet",
        "Investment" => b.Allocated > 0
            ? (b.Balance <= 0 ? $"{CurrencyFormatter.Format(b.Allocated)} contributed · fully funded" : $"{CurrencyFormatter.Format(b.Allocated - b.Balance)} contributed")
            : "No allocation yet",
        "Wants" => b.Allocated > 0
            ? $"{CurrencyFormatter.Format(b.Balance)} left of {CurrencyFormatter.Format(b.Allocated)}"
            : "No allocation yet",
        _ => "No allocation yet"
    };

    private static string IconFor(string type) => type switch
    {
        "Fixed" => "check",
        "Flexible" => "swap",
        "Investment" => "trending-up",
        "Wants" => "smile",
        _ => "wallet"
    };

    private static string BgTint(string type) => type switch
    {
        "Fixed" => "var(--mv-bucket-fixed-bg)",
        "Flexible" => "var(--mv-bucket-flexible-bg)",
        "Investment" => "var(--mv-bucket-savings-bg)",
        "Wants" => "var(--mv-bucket-reserve-bg)",
        _ => "var(--mv-bucket-reserve-bg)"
    };
    private static string TextTint(string type) => type switch
    {
        "Fixed" => "var(--mv-bucket-fixed-text)",
        "Flexible" => "var(--mv-bucket-flexible-text)",
        "Investment" => "var(--mv-bucket-savings-text)",
        "Wants" => "var(--mv-bucket-reserve-text)",
        _ => "var(--mv-bucket-reserve-text)"
    };
}
