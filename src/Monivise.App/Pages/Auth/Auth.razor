@page "/login"
@page "/register"
@layout AuthLayout
@attribute [AllowAnonymous]
@inherits FluxorComponent
@inject IDispatcher Dispatcher
@inject IState<AuthState> AuthState
@inject NavigationManager Nav

<div class="mv-shell--auth__content" style="min-height:100dvh; display:flex; flex-direction:column; padding:0 24px; box-sizing:border-box;">

    <div style="padding-top:64px; display:flex; flex-direction:column; align-items:center; gap:8px;">
        <div style="width:40px; height:40px; display:flex; align-items:center; justify-content:center;">
            <svg width="34" height="34" viewBox="0 0 32 32" fill="none">
                <path d="M7 24 V8 L16 17 L25 8 V24" stroke="#16181d" stroke-width="2.4" stroke-linecap="square" stroke-linejoin="miter" />
                <circle cx="16" cy="27.5" r="1.9" fill="#16181d" />
                <circle cx="20.5" cy="27.5" r="1.3" fill="#16181d" opacity="0.65" />
                <circle cx="24" cy="27.5" r="0.8" fill="#16181d" opacity="0.4" />
            </svg>
        </div>
        <div style="font-size:13px; font-weight:600; color:#5b606b; letter-spacing:0.02em;">Monivise</div>
    </div>

    <div style="flex:1; display:flex; flex-direction:column; justify-content:center; padding:32px 0;">

        @if (showSuccess)
        {
            <div style="display:flex; flex-direction:column; align-items:center; gap:16px; padding:40px 0; animation:mv-fade-up 0.4s ease;">
                <svg width="52" height="52" viewBox="0 0 52 52">
                    <circle cx="26" cy="26" r="25" fill="none" stroke="#1d9e75" stroke-width="2" opacity="0.25" />
                    <path d="M15 27l7 7 15-15" fill="none" stroke="#1d9e75" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="24" style="animation:mv-check 0.5s ease forwards;" />
                </svg>
                <div style="font-size:15px; color:#16181d; font-weight:500;">@(isRegister ? "Account created" : "Signed in")</div>
            </div>
        }
        else
        {
            <div>
                <div style="margin-bottom:28px;">
                    <div style="font-size:28px; font-weight:600; color:#16181d; letter-spacing:-0.01em;">@(isRegister ? "Create your account" : "Welcome back")</div>
                    <div style="font-size:15px; color:#5b606b; margin-top:6px;">@(isRegister ? "Takes under a minute." : "Sign in to see where you stand.")</div>
                </div>

                @if (!string.IsNullOrEmpty(AuthState.Value.ErrorMessage))
                {
                    <div style="background:#fbe9e9; color:#d64545; padding:12px 14px; border-radius:10px; margin-bottom:16px; font-size:13px; border-left:3px solid #d64545;">
                        @AuthState.Value.ErrorMessage
                    </div>
                }

                <form @onsubmit="HandleSubmit" style="display:flex; flex-direction:column; gap:16px;">

                    @if (isRegister)
                    {
                        <div style="display:flex; flex-direction:column; gap:6px;">
                            <label style="font-size:13px; color:#5b606b; font-weight:500;">Display name</label>
                            <input type="text" value="@name" @oninput="e => name = e.Value?.ToString() ?? string.Empty" placeholder="Your name"
                                   style="height:52px; padding:0 16px; border-radius:12px; border:1px solid #e4e6ea; background:#ffffff; font-size:15px; color:#16181d; box-sizing:border-box; outline:none;" />
                        </div>
                    }

                    <div style="display:flex; flex-direction:column; gap:6px;">
                        <label style="font-size:13px; color:#5b606b; font-weight:500;">Email</label>
                        <input type="email" value="@email" @oninput="e => { email = e.Value?.ToString() ?? string.Empty; emailError = string.Empty; }" placeholder="you@email.com"
                               style="@FieldStyle(emailError)" />
                        @if (!string.IsNullOrEmpty(emailError))
                        {
                            <div style="font-size:13px; color:#d64545; display:flex; align-items:center; gap:6px; animation:mv-fade-up 0.2s ease;">
                                <div style="width:4px; height:4px; border-radius:50%; background:#d64545; flex:none;"></div>@emailError
                            </div>
                        }
                    </div>

                    <div style="display:flex; flex-direction:column; gap:6px;">
                        <label style="font-size:13px; color:#5b606b; font-weight:500;">Password</label>
                        <input type="password" value="@password" @oninput="e => { password = e.Value?.ToString() ?? string.Empty; passwordError = string.Empty; }" placeholder="••••••••"
                               style="@FieldStyle(passwordError)" />
                        @if (!string.IsNullOrEmpty(passwordError))
                        {
                            <div style="font-size:13px; color:#d64545; display:flex; align-items:center; gap:6px; animation:mv-fade-up 0.2s ease;">
                                <div style="width:4px; height:4px; border-radius:50%; background:#d64545; flex:none;"></div>@passwordError
                            </div>
                        }
                    </div>

                    @if (isRegister)
                    {
                        <div style="display:flex; flex-direction:column; gap:6px;">
                            <label style="font-size:13px; color:#5b606b; font-weight:500;">Confirm password</label>
                            <input type="password" value="@confirmPassword" @oninput="e => { confirmPassword = e.Value?.ToString() ?? string.Empty; confirmError = string.Empty; }" placeholder="••••••••"
                                   style="@FieldStyle(confirmError)" />
                            @if (!string.IsNullOrEmpty(confirmError))
                            {
                                <div style="font-size:13px; color:#d64545; display:flex; align-items:center; gap:6px; animation:mv-fade-up 0.2s ease;">
                                    <div style="width:4px; height:4px; border-radius:50%; background:#d64545; flex:none;"></div>@confirmError
                                </div>
                            }
                        </div>
                    }

                    <div style="padding-top:4px;">
                        <button type="submit" disabled="@AuthState.Value.IsLoading"
                                style="@SubmitButtonStyle() width:100%; height:52px; border-radius:12px; border:none; color:#ffffff; font-size:15px; font-weight:600; display:flex; align-items:center; justify-content:center; transition:background 0.2s ease;">
                            @if (AuthState.Value.IsLoading)
                            {
                                <div style="width:18px; height:18px; border-radius:50%; border:2px solid rgba(255,255,255,0.35); border-top-color:#ffffff; animation:mv-spin 0.7s linear infinite;"></div>
                            }
                            else
                            {
                                <span>@(isRegister ? "Create account" : "Sign in")</span>
                            }
                        </button>
                    </div>
                </form>
            </div>
        }
    </div>

    @if (!showSuccess)
    {
        <div style="padding-bottom:28px; display:flex; flex-direction:column; gap:20px;">
            <div style="text-align:center; font-size:14px; color:#5b606b;">
                @(isRegister ? "Already have an account?" : "New to Monivise?")
                <a href="#" @onclick="ToggleMode" @onclick:preventDefault="true" style="color:#16181d; font-weight:600; text-decoration:none;">
                    @(isRegister ? "Sign in" : "Create one")
                </a>
            </div>
        </div>
    }
</div>

<style>
    @@keyframes mv-spin { to { transform: rotate(360deg); } }
    @@keyframes mv-check { from { stroke-dashoffset: 24; } to { stroke-dashoffset: 0; } }
    @@keyframes mv-fade-up { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
</style>

@code {
    private bool isRegister;
    private string name = "";
    private string email = "";
    private string password = "";
    private string confirmPassword = "";
    private string emailError = "";
    private string passwordError = "";
    private string confirmError = "";
    private bool showSuccess;
    private bool hasHandledSuccess;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        isRegister = Nav.Uri.EndsWith("/register", StringComparison.OrdinalIgnoreCase);
        Dispatcher.Dispatch(new ClearAuthErrorAction());
    }

    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);
        if (AuthState.Value.IsAuthenticated && !hasHandledSuccess)
        {
            hasHandledSuccess = true;
            showSuccess = true;
            StateHasChanged();
            _ = CompleteSuccessTransition();
        }
    }

    private async Task CompleteSuccessTransition()
    {
        await Task.Delay(900);
        Nav.NavigateTo(isRegister ? "/onboarding" : "/dashboard");
    }

    private void ToggleMode()
    {
        isRegister = !isRegister;
        emailError = passwordError = confirmError = "";
        Dispatcher.Dispatch(new ClearAuthErrorAction());
        Nav.NavigateTo(isRegister ? "/register" : "/login", replace: true);
    }

    private bool Validate()
    {
        emailError = passwordError = confirmError = "";

        if (string.IsNullOrWhiteSpace(email))
            emailError = "Enter your email";
        else if (!System.Text.RegularExpressions.Regex.IsMatch(email, @"^[^\s@]+@[^\s@]+\.[^\s@]+$"))
            emailError = "That email doesn't look right";

        if (string.IsNullOrEmpty(password))
            passwordError = "Enter your password";
        else if (isRegister && password.Length < 8)
            passwordError = "Use at least 8 characters";

        if (isRegister && confirmPassword != password)
            confirmError = "Passwords don't match";

        return string.IsNullOrEmpty(emailError) && string.IsNullOrEmpty(passwordError) && string.IsNullOrEmpty(confirmError);
    }

    private void HandleSubmit()
    {
        if (AuthState.Value.IsLoading) return;
        if (!Validate()) return;

        if (isRegister)
            Dispatcher.Dispatch(new RegisterAction(name.Trim(), email.Trim(), password));
        else
            Dispatcher.Dispatch(new LoginAction(email.Trim(), password));
    }

    private bool CanSubmit() =>
        !string.IsNullOrWhiteSpace(email) && !string.IsNullOrEmpty(password) &&
        (!isRegister || (!string.IsNullOrWhiteSpace(name) && !string.IsNullOrEmpty(confirmPassword)));

    private string FieldStyle(string error) =>
        $"height:52px; padding:0 16px; border-radius:12px; border:1px solid {(string.IsNullOrEmpty(error) ? "#e4e6ea" : "#d64545")}; background:#ffffff; font-size:15px; color:#16181d; box-sizing:border-box; outline:none;";

    private string SubmitButtonStyle() =>
        $"background:{((CanSubmit() && !AuthState.Value.IsLoading) ? "#16181d" : "#a8abb2")}; cursor:{(AuthState.Value.IsLoading ? "default" : "pointer")};";
}