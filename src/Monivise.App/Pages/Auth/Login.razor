@page "/login"
@inherits FluxorComponent
@layout AuthLayout
@attribute [AllowAnonymous]

@using Monivise.App.DTOs
@using Monivise.App.State
@using Monivise.App.State.Actions

@inject IDispatcher Dispatcher
@inject IState<AuthState> AuthState

<div class="mv-auth-container">
    <div class="mv-auth-brand">
        <h2 style="font-size: var(--mv-fs-xs); font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin: 0; color: var(--mv-text-tertiary);">MONIVISE</h2>
    </div>

    <h1 style="font-size: 28px; font-weight: 700; margin: 0 0 var(--mv-space-2); color: var(--mv-text-primary);">Welcome back</h1>
    <p style="font-size: var(--mv-fs-sm); color: var(--mv-text-tertiary); margin: 0 0 var(--mv-space-7);">Sign in to continue to your dashboard</p>

    @if (!string.IsNullOrEmpty(AuthState.Value.ErrorMessage))
    {
        <div style="background: var(--mv-danger-bg); color: var(--mv-danger-text); padding: var(--mv-space-3) var(--mv-space-4); border-radius: var(--mv-radius-lg); margin-bottom: var(--mv-space-5); font-size: var(--mv-fs-sm); border-left: 3px solid var(--mv-danger);">
            <strong style="font-weight: 600;">Error:</strong> @AuthState.Value.ErrorMessage
        </div>
    }

    <form @onsubmit="HandleLogin" style="display: flex; flex-direction: column; gap: var(--mv-space-5);">
        <Input Id="email" Label="Email" Type="email" @bind-Value="Email" Placeholder="you@example.com" Disabled="@AuthState.Value.IsLoading" Autocomplete="email" />
        <Input Id="password" Label="Password" Type="password" @bind-Value="Password" Placeholder="Enter your password" Disabled="@AuthState.Value.IsLoading" Autocomplete="current-password" />

        <Button Variant="primary"
                Label="@(AuthState.Value.IsLoading ? "Signing in..." : "Sign in")"
                ButtonType="submit"
                IsDisabled="@AuthState.Value.IsLoading" />
    </form>
    <div style="display: flex; flex-direction: column; align-items: center; gap: var(--mv-space-2); margin-top: var(--mv-space-5); padding-top: var(--mv-space-5); border-top: 1px solid var(--mv-border);">
        <a href="/forgot-password" style="color: var(--mv-text-secondary); text-decoration: none; font-size: var(--mv-fs-sm);">Forgot password?</a>
        <span style="font-size: var(--mv-fs-sm); color: var(--mv-text-tertiary);">
            New here? <a href="/register" style="color: var(--mv-accent); text-decoration: none; font-weight: 600;">Create account</a>
        </span>
    </div>
</div>

@code {
    private string Email = string.Empty;
    private string Password = string.Empty;

    private void HandleLogin()
    {
        Dispatcher.Dispatch(new LoginAction(Email.Trim(), Password));
    }
    protected override void OnInitialized()
    {
        base.OnInitialized();
        Dispatcher.Dispatch(new ClearAuthErrorAction());
    }
}