@using Monivise.App.State.Actions;
@page "/settings"
@layout AppShell
@attribute [Authorize]
@inject IDispatcher Dispatcher

<p style="font-size:var(--mv-fs-sm);font-weight:600;color:var(--mv-text-secondary);margin:0 0 var(--mv-space-4);">Settings</p>

<div style="display:flex;flex-direction:column;gap:8px;margin-bottom:var(--mv-space-6);">
    <div class="mv-card" style="cursor:pointer;" @onclick="() => showLogoutConfirm = true">
        <div style="display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:var(--mv-fs-md);">Log out</span>
            <span style="color:var(--mv-text-tertiary);">&rarr;</span>
        </div>
    </div>
    <div class="mv-card">
        <div style="display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:var(--mv-fs-md);">Dark mode</span>
            <span style="color:var(--mv-accent);font-size:var(--mv-fs-xs);font-weight:700;">Always on</span>
        </div>
    </div>
</div>

@if (showLogoutConfirm)
{
    <div style="position:absolute;inset:0;background:rgba(0,0,0,0.45);display:flex;align-items:center;justify-content:center;z-index:40;">
        <div class="mv-card mv-scale-in" style="width:80%;background:var(--mv-surface);">
            <p style="font-weight:600;margin:0 0 4px;">Log out?</p>
            <p style="font-size:var(--mv-fs-sm);color:var(--mv-text-secondary);margin:0 0 var(--mv-space-4);">You'll need to sign in again.</p>
            <div style="display:flex;gap:10px;">
                <Button Variant="secondary" OnClick="() => showLogoutConfirm = false">Cancel</Button>
                <Button Variant="danger" OnClick="ConfirmLogout">Log out</Button>
            </div>
        </div>
    </div>
}

@code {
    private bool showLogoutConfirm;

    private void ConfirmLogout()
    {
        showLogoutConfirm = false;
        Dispatcher.Dispatch(new LogoutAction());
    }
}
